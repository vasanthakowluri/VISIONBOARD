{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adfdevlorealus"
		},
		"LS_PARENT_SQLSERVER_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_PARENT_SQLSERVER'"
		},
		"LS_CHILD_SQLSERVER_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_CHILD_SQLSERVER'"
		},
		"ADLS_SQL_PARQUET_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ADLS_SQL_PARQUET'"
		},
		"LS_ONPREM_SQLSERVER_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_ONPREM_SQLSERVER'"
		},
		"AzureKeyVault1_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://mysecretekeyvault.vault.azure.net/"
		},
		"LS_PARENT_SQLSERVER_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "MSI"
		},
		"LS_PARENT_SQLSERVER_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "visionboardproject"
		},
		"LS_PARENT_SQLSERVER_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sa"
		},
		"LS_CHILD_SQLSERVER_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "MSI"
		},
		"LS_CHILD_SQLSERVER_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "visionboardproject"
		},
		"LS_CHILD_SQLSERVER_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sa"
		},
		"ADLS_SQL_PARQUET_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevlorealus.dfs.core.windows.net"
		},
		"LS_ONPREM_SQLSERVER_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "MSI"
		},
		"LS_ONPREM_SQLSERVER_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "visionboardproject"
		},
		"LS_ONPREM_SQLSERVER_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sa"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adfdevlorealus_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ADLS_SQL_PARQUET_accountKey": {
						"value": "[parameters('ADLS_SQL_PARQUET_accountKey')]"
					},
					"LS_PARENT_SQLSERVER_password": {
						"value": "[parameters('LS_PARENT_SQLSERVER_password')]"
					},
					"LS_CHILD_SQLSERVER_password": {
						"value": "[parameters('LS_CHILD_SQLSERVER_password')]"
					},
					"LS_ONPREM_SQLSERVER_password": {
						"value": "[parameters('LS_ONPREM_SQLSERVER_password')]"
					},
					"AzureKeyVault1_properties_typeProperties_baseUrl": {
						"value": "[parameters('AzureKeyVault1_properties_typeProperties_baseUrl')]"
					},
					"ADLS_SQL_PARQUET_properties_typeProperties_url": {
						"value": "[parameters('ADLS_SQL_PARQUET_properties_typeProperties_url')]"
					},
					"LS_PARENT_SQLSERVER_properties_typeProperties_server": {
						"value": "[parameters('LS_PARENT_SQLSERVER_properties_typeProperties_server')]"
					},
					"LS_PARENT_SQLSERVER_properties_typeProperties_database": {
						"value": "[parameters('LS_PARENT_SQLSERVER_properties_typeProperties_database')]"
					},
					"LS_PARENT_SQLSERVER_properties_typeProperties_userName": {
						"value": "[parameters('LS_PARENT_SQLSERVER_properties_typeProperties_userName')]"
					},
					"LS_CHILD_SQLSERVER_properties_typeProperties_server": {
						"value": "[parameters('LS_CHILD_SQLSERVER_properties_typeProperties_server')]"
					},
					"LS_CHILD_SQLSERVER_properties_typeProperties_database": {
						"value": "[parameters('LS_CHILD_SQLSERVER_properties_typeProperties_database')]"
					},
					"LS_CHILD_SQLSERVER_properties_typeProperties_userName": {
						"value": "[parameters('LS_CHILD_SQLSERVER_properties_typeProperties_userName')]"
					},
					"LS_ONPREM_SQLSERVER_properties_typeProperties_server": {
						"value": "[parameters('LS_ONPREM_SQLSERVER_properties_typeProperties_server')]"
					},
					"LS_ONPREM_SQLSERVER_properties_typeProperties_database": {
						"value": "[parameters('LS_ONPREM_SQLSERVER_properties_typeProperties_database')]"
					},
					"LS_ONPREM_SQLSERVER_properties_typeProperties_userName": {
						"value": "[parameters('LS_ONPREM_SQLSERVER_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}